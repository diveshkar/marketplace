{
  "name": "@marketplace/local-api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "db:init": "tsx scripts/init-dynamodb.ts",
    "db:seed": "tsx scripts/seed-dynamodb.ts",
    "db:seed-taxonomy": "tsx scripts/seed-taxonomy.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.712.0",
    "@aws-sdk/client-s3": "^3.712.0",
    "@aws-sdk/lib-dynamodb": "^3.712.0",
    "@aws-sdk/s3-request-presigner": "^3.712.0",
    "@marketplace/shared-subscriptions": "workspace:*",
    "@marketplace/shared-types": "workspace:*",
    "@marketplace/shared-utils": "workspace:*",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "sharp": "^0.34.5",
    "stripe": "^21.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.1"
  }
}
