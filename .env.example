# Windows, DynamoDB Local JAR: set DYNAMODB_LOCAL_HOME to the folder with DynamoDBLocal.jar
# (see scripts/start-dynamodb-local.bat). Optional; not read by Node, only for your shell/bat setup.

NODE_ENV=local
PORT=4000
AWS_REGION=ap-south-1
DYNAMODB_ENDPOINT=http://localhost:8000
DYNAMODB_TABLE_USERS=marketplace-local-users
DYNAMODB_TABLE_LISTINGS=marketplace-local-listings
DYNAMODB_TABLE_FAVORITES=marketplace-local-favorites
DYNAMODB_TABLE_INQUIRIES=marketplace-local-inquiries
DYNAMODB_TABLE_REPORTS=marketplace-local-reports
DYNAMODB_TABLE_SUBSCRIPTIONS=marketplace-local-subscriptions
UPLOAD_DIR=./.local/uploads
# Phase 5 — uploads: local (PUT /uploads/local + JWT) or s3 (presigned PUT)
STORAGE_DRIVER=local
# S3_BUCKET=your-bucket-from-terraform-output
S3_UPLOAD_PREFIX=listings
# Optional: full public base for upload URLs (else http://localhost:PORT)
# API_PUBLIC_URL=http://localhost:4000
UPLOAD_MAX_BYTES=5242880
UPLOAD_URL_TTL_SEC=600
JWT_SECRET=local-dev-secret
JWT_EXPIRES_IN=7d
